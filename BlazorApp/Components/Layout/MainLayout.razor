@inherits LayoutComponentBase
@inject ObservedStudentsState ObservedState
@implements IDisposable

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-dark bg-dark px-3">
        <a class="navbar-brand" href="/">StudentPanel</a>
        <div class="d-flex gap-3 align-items-center">
            <NavLink class="nav-link text-white" href="/students">
                Students
            </NavLink>
            <NavLink class="nav-link text-white" href="/observed">
                Observed
                <span class="badge bg-warning text-dark ms-1">
                    @ObservedState.Observed.Count
                </span>
            </NavLink>
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        ObservedState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ObservedState.OnChange -= StateHasChanged;
    }
}